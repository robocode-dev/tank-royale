{
  "suite": "event-priorities",
  "description": "Verifies event criticality and default priorities across all platforms",
  "tests": [
    {
      "id": "TR-API-EVT-002-death",
      "description": "DeathEvent is critical",
      "type": "positive",
      "method": "isCritical",
      "args": ["DeathEvent"],
      "expected": { "returns": true }
    },
    {
      "id": "TR-API-EVT-002-won-round",
      "description": "WonRoundEvent is critical",
      "type": "positive",
      "method": "isCritical",
      "args": ["WonRoundEvent"],
      "expected": { "returns": true }
    },
    {
      "id": "TR-API-EVT-002-skipped-turn",
      "description": "SkippedTurnEvent is critical",
      "type": "positive",
      "method": "isCritical",
      "args": ["SkippedTurnEvent"],
      "expected": { "returns": true }
    },
    {
      "id": "TR-API-EVT-003-bot-death",
      "description": "BotDeathEvent is non-critical",
      "type": "positive",
      "method": "isCritical",
      "args": ["BotDeathEvent"],
      "expected": { "returns": false }
    },
    {
      "id": "TR-API-EVT-003-bot-hit-bot",
      "description": "BotHitBotEvent is non-critical",

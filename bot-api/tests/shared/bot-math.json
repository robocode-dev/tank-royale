      "description": "Bullet speed for power 1.0 is 17.0",
      "type": "positive",
      "method": "calcBulletSpeed",
      "args": [1.0],
      "expected": { "returns": 17.0 }
    },
    {
      "id": "TR-API-BOT-004-speed-2.0",
      "description": "Bullet speed for power 2.0 is 14.0",
      "type": "positive",
      "method": "calcBulletSpeed",
      "args": [2.0],
      "expected": { "returns": 14.0 }
    },
    {
      "id": "TR-API-BOT-004-speed-3.0",
      "description": "Bullet speed for power 3.0 is 11.0",
      "type": "positive",
      "method": "calcBulletSpeed",
      "args": [3.0],
      "expected": { "returns": 11.0 }
    },
    {
      "id": "TR-API-BOT-005-heat-0.1",
      "description": "Gun heat for power 0.1 is 1.02",
      "type": "positive",
      "method": "calcGunHeat",
      "args": [0.1],
      "expected": { "returns": 1.02 }
    },
    {
      "id": "TR-API-BOT-005-heat-1.0",
      "description": "Gun heat for power 1.0 is 1.2",
      "type": "positive",
      "method": "calcGunHeat",
      "args": [1.0],
      "expected": { "returns": 1.2 }
    },
    {
      "id": "TR-API-BOT-005-heat-2.0",
      "description": "Gun heat for power 2.0 is 1.4",
      "type": "positive",
      "method": "calcGunHeat",
      "args": [2.0],
      "expected": { "returns": 1.4 }
    },
    {
      "id": "TR-API-BOT-005-heat-3.0",
      "description": "Gun heat for power 3.0 is 1.6",
      "type": "positive",
      "method": "calcGunHeat",
      "args": [3.0],
      "expected": { "returns": 1.6 }
    },
    {
      "id": "TR-API-BOT-006-turnrate-0",
      "description": "Max turn rate at speed 0 is 10.0",
      "type": "positive",
      "method": "calcMaxTurnRate",
      "args": [0],
      "expected": { "returns": 10.0 }
    },
    {
      "id": "TR-API-BOT-006-turnrate-5",
      "description": "Max turn rate at speed 5 is 6.25",
      "type": "positive",
      "method": "calcMaxTurnRate",
      "args": [5],
      "expected": { "returns": 6.25 }
    },
    {
      "id": "TR-API-BOT-006-turnrate-8",
      "description": "Max turn rate at speed 8 is 4.0",
      "type": "positive",
      "method": "calcMaxTurnRate",
      "args": [8],
      "expected": { "returns": 4.0 }
    },
    {
      "id": "TR-API-BOT-006-turnrate-10",
      "description": "Max turn rate at speed 10 is 4.0 (clamped)",
      "type": "positive",
      "method": "calcMaxTurnRate",
      "args": [10],
      "expected": { "returns": 4.0 }
    }
  ]
}

# All text files: LF in repo and working tree
* text=auto eol=lf

# Windows batch/command files — keep CRLF for CMD compatibility on older Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicitly binary — no line-ending or encoding conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.jar binary
*.class binary
*.pdf binary

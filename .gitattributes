# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly binary — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.jar binary
*.class binary
*.pdf binary

# Java .properties files use ISO-8859-1 encoding — prevent automatic charset conversion
*.properties text eol=lf working-tree-encoding=ISO-8859-1
